# ------------------------------------------------------------------------------
# CarbonPilot Backend Environment Configuration
# ------------------------------------------------------------------------------

# -----------------
# REQUIRED SECRETS
# -----------------
# Get your free Groq API key from: https://console.groq.com/keys
# This is strictly required for the OCR Vision pipeline and LLM Scenario Parsing.
GROQ_API_KEY=gsk_your_groq_api_key_here

# -----------------
# OPTIONAL CONFIG
# -----------------
# Deployment environment. Defaults to "development". 
# Set to "production" to enforce production security rules.
ENVIRONMENT=development


# Comma-separated list of allowed frontend origins for CORS.
# Defaults to "http://localhost:3000" if left blank.
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.web.app
